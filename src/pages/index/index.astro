---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getPrimaryAuthorLabel,
  getPrimaryAuthorSortKey,
  getPublishedWorks,
  getSortablePublicationYear,
  sortWorksByTitle,
} from "../../lib/content";

const rankedWorks = await getPublishedWorks();
const works = sortWorksByTitle(rankedWorks);
const workCount = works.length;
---

<BaseLayout title="Master index | Forbidden Books Wiki" description="A full index of all published works in the Forbidden Books Wiki.">
  <section class="panel index-panel">
    <div class="panel__header">
      <div>
        <p class="eyebrow">Master index</p>
        <h1>All banned works in the current corpus</h1>
      </div>
      <p class="panel__eyebrow-detail">{workCount} published records</p>
    </div>

    <p class="hero__summary">
      This page lists every published work currently in the dataset. By default it is alphabetized by title. Click the
      table headers to sort by title, author, or publication date in ascending or descending order.
    </p>

    <div class="table-wrap">
      <table class="ban-table index-table">
        <thead>
          <tr>
            <th scope="col" data-index-header data-sort-key="title" aria-sort="ascending">
              <button class="index-table__sort-button index-table__sort-button--active" type="button" data-index-sort-button data-sort="title" data-direction="asc">
                <span>Title</span>
                <span class="index-table__sort-indicator" aria-hidden="true"></span>
              </button>
            </th>
            <th scope="col" data-index-header data-sort-key="year" aria-sort="none">
              <button class="index-table__sort-button" type="button" data-index-sort-button data-sort="year" data-direction="none">
                <span>Publication date</span>
                <span class="index-table__sort-indicator" aria-hidden="true"></span>
              </button>
            </th>
            <th scope="col" data-index-header data-sort-key="author" aria-sort="none">
              <button class="index-table__sort-button" type="button" data-index-sort-button data-sort="author" data-direction="none">
                <span>Author(s)</span>
                <span class="index-table__sort-indicator" aria-hidden="true"></span>
              </button>
            </th>
          </tr>
        </thead>
        <tbody data-index-body>
          {
            works.map((work, index) => (
              <tr
                data-index-row
                data-title={work.data.title.toLowerCase()}
                data-author={getPrimaryAuthorSortKey(work)}
                data-year={String(getSortablePublicationYear(work.data.publishedYearText))}
                data-default-order={String(index)}
              >
                <td>
                  <a class="index-table__title" href={`/works/${work.data.slug}/`}>
                    {work.data.title}
                  </a>
                </td>
                <td>{work.data.publishedYearText ?? "Unknown"}</td>
                <td>{getPrimaryAuthorLabel(work)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="note">
      Publication dates are normalized only for sorting. Ancient texts, centuries, and approximate dates keep their original
      labels in the table.
    </p>
  </section>

  <script is:inline>
    const body = document.querySelector("[data-index-body]");
    const buttons = Array.from(document.querySelectorAll("[data-index-sort-button]"));
    const headers = Array.from(document.querySelectorAll("[data-index-header]"));

    if (body && buttons.length && headers.length) {
      const rows = Array.from(body.querySelectorAll("[data-index-row]"));
      const collator = new Intl.Collator("en", { sensitivity: "base" });

      const comparators = {
        title: (left, right) =>
          collator.compare(left.dataset.title ?? "", right.dataset.title ?? "") ||
          Number(left.dataset.defaultOrder ?? "0") - Number(right.dataset.defaultOrder ?? "0"),
        author: (left, right) =>
          collator.compare(left.dataset.author ?? "", right.dataset.author ?? "") ||
          collator.compare(left.dataset.title ?? "", right.dataset.title ?? ""),
        year: (left, right) =>
          Number(left.dataset.year ?? Number.MAX_SAFE_INTEGER) - Number(right.dataset.year ?? Number.MAX_SAFE_INTEGER) ||
          collator.compare(left.dataset.title ?? "", right.dataset.title ?? ""),
      };

      const setActiveHeader = (sortKey, direction) => {
        buttons.forEach((button) => {
          const active = button.dataset.sort === sortKey;
          button.dataset.direction = active ? direction : "none";
          button.classList.toggle("index-table__sort-button--active", active);
          button.setAttribute("aria-pressed", String(active));
        });

        headers.forEach((header) => {
          const active = header.dataset.sortKey === sortKey;
          header.setAttribute("aria-sort", active ? (direction === "desc" ? "descending" : "ascending") : "none");
        });
      };

      const applySort = (sortKey, direction) => {
        const directionMultiplier = direction === "desc" ? -1 : 1;
        rows.sort((left, right) => directionMultiplier * (comparators[sortKey] ?? comparators.title)(left, right));
        rows.forEach((row) => body.appendChild(row));
        setActiveHeader(sortKey, direction);

        const url = new URL(window.location.href);
        if (sortKey === "title") {
          url.searchParams.delete("sort");
        } else {
          url.searchParams.set("sort", sortKey);
        }
        if (direction === "asc" && sortKey === "title") {
          url.searchParams.delete("dir");
        } else {
          url.searchParams.set("dir", direction);
        }
        history.replaceState(null, "", `${url.pathname}${url.search}`);
      };

      const params = new URLSearchParams(window.location.search);
      const initialSort = ["title", "author", "year"].includes(params.get("sort") ?? "") ? params.get("sort") : "title";
      const initialDirection = ["asc", "desc"].includes(params.get("dir") ?? "") ? params.get("dir") : "asc";

      applySort(initialSort ?? "title", initialDirection ?? "asc");

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const sortKey = button.dataset.sort ?? "title";
          const activeDirection = button.dataset.direction;
          const isActive = button.classList.contains("index-table__sort-button--active");
          const nextDirection = isActive && activeDirection === "asc" ? "desc" : "asc";
          applySort(sortKey, nextDirection);
        });
      });
    }
  </script>
</BaseLayout>
