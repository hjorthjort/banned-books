---
interface EventRow {
  dateText: string;
  jurisdictionName: string;
  actionType: string;
  reasonSummary: string;
  note: string;
}

interface Props {
  rows: EventRow[];
}

const { rows } = Astro.props;
---

<div class="table-wrap">
  <table class="ban-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Jurisdiction</th>
        <th>Action</th>
        <th>Reason</th>
        <th>Note</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            <td>{row.dateText}</td>
            <td>{row.jurisdictionName}</td>
            <td>{row.actionType}</td>
            <td>{row.reasonSummary}</td>
            <td>{row.note}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

